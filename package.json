  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "preview": "vite preview",
    "build": "vite build --mode production",
    "start": "vite --mode production",
    "build:env": "vite build --mode development",
    "test": "vitest --config vite.config.test.js",
    "test:coverage": "vitest --coverage --config vite.config.test.js",
    "test:unit": "vitest run src/tests/unit --config vite.config.test.js",
    "test:component": "vitest run src/tests/component --config vite.config.test.js",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "cypress run",
    "test:all": "npm run test:unit && npm run test:component && npm run test:e2e",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.8.4",
    "bpmn-js": "^16.0.0",
    "bpmn-js-properties-panel": "^4.0.0",
    "camunda-bpmn-moddle": "^7.0.0",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.7",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^1.6.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-standard": "^9.0.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.36.0",
    "eslint-plugin-vue": "^10.5.0",
