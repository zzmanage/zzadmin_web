    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^24.1.0",
    "msw": "^2.11.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "sass": "^1.86.0",
    "unplugin-auto-import": "^19.1.1",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.2.0",
    "vitest": "^1.6.0"
  }
