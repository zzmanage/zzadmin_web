NODE_ENV=development
VITE_APP_API_BASE_URL="http://localhost:8000/"

# API服务优化相关配置
# API缓存配置
VITE_APP_API_CACHE_ENABLED=true
VITE_APP_API_CACHE_TTL=30000 # 缓存时间(毫秒)
VITE_APP_API_CACHE_SIZE=100 # 缓存条目数量上限

# API请求配置
VITE_APP_API_TIMEOUT=30000 # 请求超时时间(毫秒)
VITE_APP_API_RETRY_ENABLED=true # 是否启用重试
VITE_APP_API_RETRY_COUNT=3 # 重试次数
VITE_APP_API_RETRY_DELAY=1000 # 重试间隔(毫秒)

# API限流配置
VITE_APP_API_RATE_LIMIT_ENABLED=false # 是否启用限流
VITE_APP_API_RATE_LIMIT_RATE=100 # 每分钟最大请求数

# API版本控制
VITE_APP_API_VERSION="v1" # 默认API版本

# 日志配置
VITE_APP_API_LOG_LEVEL="info" # API日志级别: debug, info, warn, error